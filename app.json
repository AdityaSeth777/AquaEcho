{
  "expo": {
    "name": "AquaEcho",
    "slug": "aquaecho",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./images/logo1.jpg",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./images/logo1.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#0066CC"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aquaecho.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./images/logo1.jpg",
        "backgroundColor": "#0066CC"
      },
      "package": "com.aquaecho.app"
    },
    "platforms": ["ios", "android"]
  }
}